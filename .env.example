# Helios runtime configuration
#
# Copy to .env for your shell/process manager if desired. Do not commit .env.

# HTTP Basic Auth username.
HELIOS_USER=advisor

# Set a stable strong password for local-network use. If unset, Helios prints
# an auto-generated password at startup.
HELIOS_PASSWORD=

# Safe default: bind only to localhost. Institutional mode rejects direct
# public/LAN binding. Put a trusted authenticated TLS reverse proxy in front of
# this localhost listener instead of exposing the waitress port.
HELIOS_HOST=127.0.0.1
HELIOS_PORT=5000

# 1 enables direct TLS for localhost development. Without explicit paths,
# Helios may create a self-signed development certificate. Institutional
# network access still requires a trusted reverse proxy in front of localhost.
HELIOS_TLS=0
HELIOS_TLS_CERT_PATH=
HELIOS_TLS_KEY_PATH=
HELIOS_TLS_TRUSTED=0

# For a trusted reverse proxy, keep Helios bound to 127.0.0.1. Configure the
# exact proxy addresses, assert TLS only after the proxy is operational, and
# never expose the waitress port directly.
HELIOS_TRUSTED_PROXY_TLS=0
HELIOS_TRUSTED_TLS=0
HELIOS_TRUSTED_PROXY_IPS=
HELIOS_TRUSTED_HOSTS=localhost,127.0.0.1

# Keep auth enabled except for trusted local tests/dev smoke checks.
HELIOS_AUTH=1

# Institutional access controls. Roles: viewer, analyst, data_steward,
# model_sponsor, independent_validator, approver, admin. Header-based SSO is
# accepted only from HELIOS_TRUSTED_PROXY_IPS; Helios never starts an IdP.
HELIOS_INSTITUTIONAL_CONTROLS=1
HELIOS_BASIC_ROLES=viewer
HELIOS_BASIC_MFA_VERIFIED=0
HELIOS_SSO_ENABLED=0
HELIOS_REQUIRE_MFA=1
HELIOS_SESSION_IDLE_SECONDS=900
HELIOS_SESSION_ABSOLUTE_SECONDS=28800
HELIOS_BACKUP_VERIFICATION_MAX_AGE_DAYS=30

# Risk-free / CD benchmark rate used by mandate anchors and Sharpe-style metrics.
HELIOS_RF=0.02

# Local SQLite store for live/uploaded price histories and uploaded model
# metadata. Keep this local; Helios stores parsed data and provenance, not raw
# upload files or API credentials. Set to "off" for ephemeral/no-persistence runs.
HELIOS_DB_PATH=.helios/helios.db

# Local persistence encryption. "auto" creates a local .helios/helios.key file
# when no key is provided. Use "required" to fail closed unless a key is present.
HELIOS_DB_ENCRYPTION=auto
HELIOS_DB_ENCRYPTION_KEY=
HELIOS_DB_ENCRYPTION_KEY_PATH=

# Optional automatic live-data polling. Set to "core" for the built-in liquid
# advisor universe, "starter_models" for all example model holdings, or provide
# a comma-separated ticker list. Helios follows an approved provider cutover
# when present, persists validated histories, and refreshes them on this interval.
HELIOS_AUTO_LIVE_SYMBOLS=core
HELIOS_AUTO_LIVE_PERIOD=2y
HELIOS_AUTO_LIVE_REFRESH_SECONDS=300
HELIOS_AUTO_LIVE_MAX_WORKERS=6

# Institutional data-quality dashboard thresholds. These tune diagnostics only;
# they do not weaken provenance gates or change analytics methodology.
HELIOS_DATA_QUALITY_STALE_DAYS=7
HELIOS_DATA_QUALITY_MIN_RESEARCH_ROWS=60
HELIOS_DATA_QUALITY_INSTITUTIONAL_ROWS=252

# Institutional provider controls. Credentials do not prove licensing. Set
# licensed/entitled only after contractual confirmation, name an accountable
# SLA owner, record side-by-side reconciliation evidence in Helios, then approve
# the primary/backup cutover. yfinance remains research-only under these gates.
HELIOS_PROVIDER_RECONCILIATION_MAX_DIFF_PCT=0.25
HELIOS_PROVIDER_RECONCILIATION_MAX_AGE_DAYS=30
HELIOS_PROVIDER_RECONCILIATION_MIN_SYMBOLS=2
HELIOS_PROVIDER_FMP_LICENSED=0
HELIOS_PROVIDER_FMP_ENTITLED=0
HELIOS_PROVIDER_FMP_SLA_OWNER=
HELIOS_PROVIDER_TIINGO_LICENSED=0
HELIOS_PROVIDER_TIINGO_ENTITLED=0
HELIOS_PROVIDER_TIINGO_SLA_OWNER=
HELIOS_PROVIDER_INTRINIO_LICENSED=0
HELIOS_PROVIDER_INTRINIO_ENTITLED=0
HELIOS_PROVIDER_INTRINIO_SLA_OWNER=

# Operations and independent-validation ownership. The webhook value is status
# metadata for a user-managed external adapter; Helios does not send to it.
HELIOS_INCIDENT_OWNER=
HELIOS_INCIDENT_WEBHOOK_URL=
HELIOS_MODEL_VALIDATION_CADENCE_DAYS=365

# Optional local model-governance approval verification. If either value is
# configured, approve/reject actions require committee identity fields and a
# matching local PIN. Prefer the SHA-256 hash form for shared machine config.
HELIOS_GOVERNANCE_APPROVER_PIN=
HELIOS_GOVERNANCE_APPROVER_PIN_HASH=

# Fund look-through (SEC EDGAR N-PORT). EDGAR is free and keyless but its
# fair-access policy asks for a User-Agent that identifies you with contact info.
# Set this to a real "Name email@example.com" before pulling look-through at any
# volume, or SEC may throttle/deny anonymous requests.
HELIOS_SEC_USER_AGENT=

# Cleaner forward fundamentals via Financial Modeling Prep. Set HELIOS_FMP_KEY
# and the forward CMA automatically prefers FMP analyst consensus (forward EPS
# growth + forward P/E) over yfinance's noisy single-quarter figure, falling back
# to yfinance per-ticker when FMP has no data. HELIOS_FMP_BASE_URL is optional
# (self-host/proxy). OpenFIGI (CUSIP->ticker for N-PORT) is used automatically
# and free; a key only raises its rate limit. Finnhub is reserved for upcoming
# news/earnings ingestion.
HELIOS_FMP_KEY=
HELIOS_FMP_BASE_URL=
HELIOS_TIINGO_KEY=
HELIOS_TIINGO_BASE_URL=https://api.tiingo.com
HELIOS_INTRINIO_KEY=
HELIOS_OPENFIGI_KEY=
HELIOS_FINNHUB_KEY=

# Optional AI Copilot. Disabled by default; Helios analytics work without AI.
HELIOS_AI_ENABLED=0
HELIOS_AI_PROVIDER=none

# Claude / Anthropic cloud provider. Keep the real key in your local environment
# only; never commit it and never expose it to frontend JavaScript.
ANTHROPIC_API_KEY=
HELIOS_AI_MODEL_ANTHROPIC=

# Local AI provider options. Helios does not download models or start servers.
HELIOS_LOCAL_AI_BACKEND=ollama
HELIOS_LOCAL_AI_BASE_URL=http://127.0.0.1:11434
HELIOS_LOCAL_AI_MODEL=
HELIOS_LOCAL_AI_TIMEOUT_S=45
HELIOS_LOCAL_AI_REQUIRE_LOCALHOST=1

# Optional OpenAI cloud provider configuration.
OPENAI_API_KEY=
HELIOS_AI_MODEL_OPENAI=

# Privacy controls for all AI providers.
HELIOS_AI_REDACT_CLIENT_NAMES=1
HELIOS_AI_SEND_HOLDINGS=0
HELIOS_AI_CACHE_TTL_S=900
