# Helios runtime configuration
#
# Copy to .env for your shell/process manager if desired. Do not commit .env.

# HTTP Basic Auth username.
HELIOS_USER=advisor

# Set a stable strong password for local-network use. If unset, Helios prints
# an auto-generated password at startup.
HELIOS_PASSWORD=

# Bind address and port. Use 127.0.0.1 for localhost-only development.
HELIOS_HOST=0.0.0.0
HELIOS_PORT=5000

# 1 serves self-signed HTTPS; 0 serves plain HTTP.
HELIOS_TLS=0

# Keep auth enabled except for trusted local tests/dev smoke checks.
HELIOS_AUTH=1

# Risk-free / CD benchmark rate used by mandate anchors and Sharpe-style metrics.
HELIOS_RF=0.02

# Local SQLite store for live/uploaded price histories and uploaded model
# metadata. Keep this local; Helios stores parsed data and provenance, not raw
# upload files or API credentials. Set to "off" for ephemeral/no-persistence runs.
HELIOS_DB_PATH=.helios/helios.db

# Optional automatic live-data polling. Set to "core" for the built-in liquid
# advisor universe, "starter_models" for all example model holdings, or provide
# a comma-separated ticker list. Helios fetches
# yfinance data into the local SQLite store and refreshes it on this interval.
HELIOS_AUTO_LIVE_SYMBOLS=
HELIOS_AUTO_LIVE_PERIOD=2y
HELIOS_AUTO_LIVE_REFRESH_SECONDS=300

# Fund look-through (SEC EDGAR N-PORT). EDGAR is free and keyless but its
# fair-access policy asks for a User-Agent that identifies you with contact info.
# Set this to a real "Name email@example.com" before pulling look-through at any
# volume, or SEC may throttle/deny anonymous requests.
HELIOS_SEC_USER_AGENT=

# Cleaner forward fundamentals via Financial Modeling Prep. Set HELIOS_FMP_KEY
# and the forward CMA automatically prefers FMP analyst consensus (forward EPS
# growth + forward P/E) over yfinance's noisy single-quarter figure, falling back
# to yfinance per-ticker when FMP has no data. HELIOS_FMP_BASE_URL is optional
# (self-host/proxy). OpenFIGI (CUSIP->ticker for N-PORT) is used automatically
# and free; a key only raises its rate limit. Finnhub is reserved for upcoming
# news/earnings ingestion.
HELIOS_FMP_KEY=
HELIOS_FMP_BASE_URL=
HELIOS_OPENFIGI_KEY=
HELIOS_FINNHUB_KEY=

# Optional AI Copilot. Disabled by default; Helios analytics work without AI.
HELIOS_AI_ENABLED=0
HELIOS_AI_PROVIDER=none

# Claude / Anthropic cloud provider. Keep the real key in your local environment
# only; never commit it and never expose it to frontend JavaScript.
ANTHROPIC_API_KEY=
HELIOS_AI_MODEL_ANTHROPIC=

# Local AI provider options. Helios does not download models or start servers.
HELIOS_LOCAL_AI_BACKEND=ollama
HELIOS_LOCAL_AI_BASE_URL=http://127.0.0.1:11434
HELIOS_LOCAL_AI_MODEL=
HELIOS_LOCAL_AI_TIMEOUT_S=45
HELIOS_LOCAL_AI_REQUIRE_LOCALHOST=1

# Optional OpenAI cloud provider placeholder.
OPENAI_API_KEY=
HELIOS_AI_MODEL_OPENAI=

# Privacy controls for all AI providers.
HELIOS_AI_REDACT_CLIENT_NAMES=1
HELIOS_AI_SEND_HOLDINGS=0
HELIOS_AI_CACHE_TTL_S=900
